<idea-plugin>
    <id>org.babelserver.intellijnostos</id>
    <name>Nostos</name>
    <vendor url="https://github.com/hallyhaa/intellij-nostos">Hallvard Ystad</vendor>

    <description><![CDATA[
    Language support for <a href="https://heynostos.tech">Nostos</a>,
    a functional-first programming language with lightweight concurrency,
    pattern matching, and non-blocking I/O.
    ]]></description>

    <change-notes><![CDATA[
    <b>0.1.0</b>
    <ul>
        <li>Initial release</li>
        <li>Syntax highlighting</li>
        <li>Parser with full language grammar support</li>
        <li>Code completion for keywords</li>
        <li>Go to Definition and Find Usages</li>
        <li>Code formatting and indentation</li>
        <li>Structure view</li>
        <li>Code folding</li>
        <li>Brace matching</li>
        <li>Line and block commenting</li>
    </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosFileType"
            fieldName="INSTANCE"
            language="Nostos"
            extensions="nos"/>
        <lang.parserDefinition
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosParserDefinition"/>
        <lang.syntaxHighlighterFactory
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosSyntaxHighlighterFactory"/>
        <lang.commenter
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosCommenter"/>
        <lang.braceMatcher
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosBraceMatcher"/>
        <lang.foldingBuilder
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosFoldingBuilder"/>
        <lang.psiStructureViewFactory
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosStructureViewFactory"/>
        <lang.findUsagesProvider
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosFindUsagesProvider"/>
        <completion.contributor
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosCompletionContributor"/>
        <lang.formatter
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosFormattingModelBuilder"/>
        <!--suppress PluginXmlI18n -->
        <projectConfigurable
            parentId="language"
            instance="org.babelserver.intellijnostos.settings.NostosSettingsConfigurable"
            id="nostos.settings"
            displayName="Nostos"/>
        <configurationType
            implementation="org.babelserver.intellijnostos.run.NostosConfigurationType"/>
        <runConfigurationProducer
            implementation="org.babelserver.intellijnostos.run.NostosRunConfigurationProducer"/>
        <runLineMarkerContributor
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.run.NostosRunLineMarkerContributor"/>
        <externalAnnotator
            language="Nostos"
            implementationClass="org.babelserver.intellijnostos.NostosExternalAnnotator"/>
    </extensions>
</idea-plugin>
